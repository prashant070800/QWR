# QWR AI Voice Bot environment template.
# Copy to .env and fill only the provider block you plan to use.

# ── Runtime ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# ── Chat provider selector ─────────────────────────────────────────────────
# Choose one: gemini | openai | anthropic
AI_PROVIDER=gemini
AI_MAX_TOKENS=512

# ── Google Gemini chat ─────────────────────────────────────────────────────
# Use when AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# ── ChatGPT / OpenAI chat ──────────────────────────────────────────────────
# To use ChatGPT:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=sk-...
OPENAI_API_KEY=

# ── Anthropic Claude chat ──────────────────────────────────────────────────
# To use Claude:
#   AI_PROVIDER=anthropic
#   AI_MODEL=claude-3-5-haiku-20241022
#   ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# ── Speech-to-text ─────────────────────────────────────────────────────────
# Choose one: stub | deepgram | google
# stub returns canned text and is only for local pipeline testing.
STT_PROVIDER=stub
STT_SILENCE_CHUNKS=10

# Use when STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# Use when STT_PROVIDER=google or TTS_PROVIDER=google
GOOGLE_APPLICATION_CREDENTIALS=

# ── Text-to-speech ─────────────────────────────────────────────────────────
# Choose one: gtts | google | stub
# gtts gives audible speech without a cloud key. stub is silence.
TTS_PROVIDER=gtts
TTS_LANGUAGE_CODE=en-IN
TTS_VOICE_NAME=en-IN-Wavenet-A

# ── QWR website context ────────────────────────────────────────────────────
QWR_WEBSITE_URL=https://questionwhatsreal.com/
QWR_CACHE_TTL_SECONDS=3600

# ── Exotel ─────────────────────────────────────────────────────────────────
EXOTEL_ACCOUNT_SID=
EXOTEL_AUTH_TOKEN=
