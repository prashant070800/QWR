# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  QWR AI Voice Bot — Environment Variables                                ║
# ║  Copy this file to .env and fill in your values.                         ║
# ║  NEVER commit .env to git.                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
LOG_LEVEL=DEBUG

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: gemini | openai | anthropic
AI_PROVIDER=gemini

# Model to use — leave blank to use the provider default:
#   gemini  → gemini-2.0-flash-exp
#   openai  → gpt-4o-mini
#   anthropic → claude-3-5-haiku-20241022
AI_MODEL='gemini-2.0-flash-exp'

# Max tokens in each AI reply (keep short for phone calls)
AI_MAX_TOKENS=512

# ── API Keys ──────────────────────────────────────────────────────────────────
# Gemini (default provider) — see README for how to generate this key
GEMINI_API_KEY='AQ.Ab8RN6L4iJsT4CUmT2gWmUvz2Wr2LpOUe_O1tNMP33nfIiYPzw'

# OpenAI (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic (only needed if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# ── STT (Speech-to-Text) ─────────────────────────────────────────────────────
# stub   = returns canned text (no API key needed, for testing)
# google = Google Cloud Speech-to-Text
# deepgram = Deepgram Nova-2
STT_PROVIDER=stub

# Number of consecutive silent audio chunks before flushing to STT
STT_SILENCE_CHUNKS=10

# Deepgram API key (only needed if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# ── TTS (Text-to-Speech) ─────────────────────────────────────────────────────
# stub   = returns silence (no API key needed, for testing)
# google = Google Cloud Text-to-Speech
TTS_PROVIDER=stub

TTS_LANGUAGE_CODE=en-IN
TTS_VOICE_NAME=en-IN-Wavenet-A

# ── Google Cloud credentials (STT + TTS) ─────────────────────────────────────
# Path to your Google service account JSON key file.
# Required only if STT_PROVIDER=google or TTS_PROVIDER=google.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# ── QWR Website Scraper ───────────────────────────────────────────────────────
QWR_WEBSITE_URL=https://questionwhatsreal.com/
# How long (seconds) to cache scraped page content in memory (default: 1 hour)
QWR_CACHE_TTL_SECONDS=3600

# ── Exotel ───────────────────────────────────────────────────────────────────
EXOTEL_ACCOUNT_SID=
EXOTEL_AUTH_TOKEN=
